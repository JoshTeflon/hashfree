{
  "name": "hashless",
  "version": "1.0.0",
  "description": "Ditch the fragment clutter. Hashless strips # from section links for clean, professional, and high-fidelity URL navigation.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown --config tsdown.config.mts",
    "build:watch": "tsdown --config tsdown.config.mts --watch",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "release": "changeset publish"
  },
  "keywords": [],
  "author": "Joshua Enikele",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/browser": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.0",
    "vitest": "^4.1.1"
  }
}
